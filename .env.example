# БД triage (pgvector/pgvector, docker-compose up -d vector-db) — kb_documents,
# client_messages, triage_results. Отдельная БД, потому что локальный
# Postgres 17 не даёт поставить extension vector без сборки из исходников.
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5433
VECTOR_DB_NAME=triage
VECTOR_DB_USER=postgres
VECTOR_DB_PASSWORD=changeme

OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b-instruct
OLLAMA_EMBED_MODEL=all-minilm

# MLflow — сервис в docker-compose хаба (Nikolay-Kolesnikov-portfolio-hub),
# порт 5501 проброшен на host
MLFLOW_TRACKING_URI=http://localhost:5501
